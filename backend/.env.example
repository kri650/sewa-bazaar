PORT=5000

# MySQL/Database (replace with your real values)
DB_HOST=srv2207.hstgr.io
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASS=your_mysql_password
DB_NAME=your_database_name
DB_POOL_SIZE=10

# Alternate names (some setups expect MYSQL_*)
MYSQL_HOST=${DB_HOST}
MYSQL_PORT=${DB_PORT}
MYSQL_USER=${DB_USER}
MYSQL_PASSWORD=${DB_PASS}
MYSQL_DATABASE=${DB_NAME}

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
